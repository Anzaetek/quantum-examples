{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{",  "close": "}" },
    { "open": "[",  "close": "]" },
    { "open": "(",  "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^(.*\\{[^}\"']*|.*\\([^)\"']*|\\s*(circuit|observable|contract|module|pipeline|systolic|struct|enum|repeat|when|stage|schedule)\\b.*)$",
    "decreaseIndentPattern": "^\\s*[)}\\]]"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
